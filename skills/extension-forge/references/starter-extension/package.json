{
  "name": "forge-extension",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "A Chrome MV3 extension starter.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "icons": "node scripts/render-icons.mjs"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.1.42",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@crxjs/vite-plugin": {
      "rollup": "^2.80.0"
    }
  }
}
