# FORGE: copy to .env and fill in. Vite exposes only VITE_-prefixed vars to the
# extension bundle (import.meta.env.VITE_*). Never put secrets you don't want
# shipped in the bundle here — extension code is fully readable by users.

# Example: a public API base URL the extension calls.
# VITE_API_BASE_URL=https://api.example.com
