# =====================================================================
# Public branding — exposed to the browser via Next.js `NEXT_PUBLIC_*`.
# =====================================================================
NEXT_PUBLIC_APP_NAME="Agent Chat"
NEXT_PUBLIC_APP_TAGLINE="Talk to your agent"

# =====================================================================
# Agent harness credentials — replace with whatever the chosen harness
# (Anthropic SDK, AI SDK, OpenAI Agents SDK, etc.) actually needs.
# The placeholder agent in src/agent.ts ignores these.
# =====================================================================
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# =====================================================================
# Optional MCP server endpoints (filled in by the agent-forge skill).
# =====================================================================
# MCP_SERVER_URLS="https://example.com/mcp"
